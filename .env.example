# Copy this file to .env and fill in real values.
# NEVER commit .env to version control (it's in .gitignore).

# --- LLM providers (the text-to-SQL demo needs at least one) ---
# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic Claude — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- Google services (Sheets, Docs, Drive, Slides) ---
# Path to the OAuth client credentials downloaded from Google Cloud Console.
# Default location is the project root.
GOOGLE_APPLICATION_CREDENTIALS=./credentials.json

# --- Optional, only if you build the Reddit demand-signals tool later ---
# Reddit — https://www.reddit.com/prefs/apps (create a "script" app)
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_USER_AGENT=FirstWorkflow/0.1 by your_username
